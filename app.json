{
  "expo": {
    "name": "UltraNotes",
    "slug": "my-notes-app",
    "version": "1.0.13",
    "orientation": "portrait",
    "owner": "epick123",
    "icon": "./assets/images/logo2.png",
    "scheme": "mynotesapp",
    "userInterfaceStyle": "automatic",
    "buildNumber": "1",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hevin.notesApp",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "10",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "UltraNotes needs access to your Photo Library so you can select photos and attach them to your notes.",
        "NSPhotoLibraryAddUsageDescription": "UltraNotes needs permission to save drawings and images to your Photo Library."
      },
      "appleTeamId": "6AHH4WLP4Z"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hevin.notesApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo2.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "expo-iap",
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      [
  "expo-build-properties",
  {
    "ios": {
      "extraPods": [
        { "name": "GoogleUtilities", "modular_headers": true },
        { "name": "FirebaseCoreInternal", "modular_headers": true },
        { "name": "FirebaseABTesting", "modular_headers": true }
      ]
    }
  }
]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb6d0d6f-0443-4263-bf7b-ff458756185b"
      }
    }
  }
}